CHAIN_BACKEND=stellar
STELLAR_NETWORK=stellar-testnet
STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_FRIENDBOT_URL=https://friendbot.stellar.org
STELLAR_METAGRAPH_CONTRACT_ID=
STELLAR_CLI_BIN=stellar
SUBNET_ID=1
ALLOW_STELLAR_PUBLIC_NETWORK=false

HOTKEY_BASE_DIR=moderntensor
COLDKEY_NAME=default
HOTKEY_NAME=validator

# Generate fresh Stellar testnet keys with:
# python scripts/bootstrap_stellar_testnet.py --generate-accounts --fund
MINER_STELLAR_SECRET=
VALIDATOR_STELLAR_SECRET=
VALIDATOR_STELLAR_PUBLIC_KEY=
VALIDATOR_ADDRESS=
VALIDATOR_UID=
VALIDATOR_API_ENDPOINT=http://127.0.0.1:8001
API_PORT=8001

REQUIRE_SIGNED_PAYLOADS=true
REQUIRE_SIGNED_MINER_RESULTS=true
REQUIRE_SIGNED_VALIDATOR_SCORES=true
API_MAX_REQUEST_BYTES=1000000
API_TASK_QUEUE_SIZE=64
API_RATE_LIMIT_PER_MINUTE=120
HTTP_TIMEOUT_SECONDS=15
CONSENSUS_CYCLE_LEDGER_LENGTH=120
CONSENSUS_NETWORK_TIMEOUT_SECONDS=10
CONSENSUS_MINI_BATCH_WAIT_SECONDS=30
CONSENSUS_NUM_MINERS_TO_SELECT=5
CONSENSUS_QUORUM_RATIO=0.6666666667
CONSENSUS_TRUST_EMA_ALPHA=0.2
CONSENSUS_STATE_RETENTION_CYCLES=3
CONSENSUS_MAX_PERFORMANCE_HISTORY_LEN=100
METAGRAPH_SCORE_SCALE=1000000
STELLAR_TOKEN_AMOUNT_SCALE=10000000
MODEL_ALLOWLIST=segmind/tiny-sd
MODEL_USE_SAFETENSORS=true
MODEL_TRUST_REMOTE_CODE=false
MODEL_MAX_RESULT_BYTES=2000000
LOG_LEVEL=INFO
